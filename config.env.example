# Copy this file to config.env (gitignored) and fill in real values.
# config.env is sourced by backup-teslamate.sh — never commit it.

# Docker Compose project name (used to find the running containers,
# e.g. "mfunk" -> container "mfunk-database-1"). See docker ps / docker compose ls.
COMPOSE_PROJECT=mfunk

# Fallback container name if COMPOSE_PROJECT lookup fails.
DB_CONTAINER=mfunk-database-1

# Must match the teslamate/database service environment in docker-compose.yml.
DATABASE_USER=teslamate
DATABASE_PASS=changeme
DATABASE_NAME=teslamate

# Fallback Grafana volume name if the compose-project label lookup fails.
# Note: compose prefixes volume names with the project, e.g. "mfunk_teslamate-grafana-data".
GRAFANA_VOLUME=mfunk_teslamate-grafana-data

# NFS mount that backups are written to (see host-rpimonitor-info.md).
NFS_MOUNT=/mnt/backup
BACKUP_ROOT=/mnt/backup/teslamate

# Local staging directory backups are written to before being moved to NFS.
STAGING_DIR=/var/tmp/teslamate-backup

# How many days of backups to keep.
RETENTION_DAYS=14
